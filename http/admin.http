@baseUrl = http://127.0.0.1:4001

### List categories
GET {{baseUrl}}/admin/categories

### List all items
GET {{baseUrl}}/admin/items

### List only memory items
GET {{baseUrl}}/admin/items?source_id=memory

### Update one item
PUT {{baseUrl}}/admin/items/doc-memory-1
content-type: application/json

{
  "text": "The user prefers concise responses when reviewing API or retrieval changes.",
  "metadata": {
    "user": "mats",
    "kind": "preference"
  },
  "source_id": "memory"
}

### Delete one item
DELETE {{baseUrl}}/admin/items/doc-memory-1

### Get oversized items
# Returns items that are potentially too large for efficient retrieval.
GET {{baseUrl}}/admin/items/oversized

### Rechunk an item (Standard)
# Re-splits a document using standard character-based chunking.
POST {{baseUrl}}/admin/items/doc-memory-1/rechunk

### Rechunk an item (LLM-assisted)
# Uses an LLM to identify logical boundaries for better chunking.
POST {{baseUrl}}/admin/items/doc-memory-1/llm-rechunk
