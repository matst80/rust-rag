{
  "type_name": "recipe",
  "title": "Recipe",
  "description": "Cooking recipe with ingredients and steps.",
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["title", "ingredients", "steps"],
    "properties": {
      "title": { "type": "string", "minLength": 1 },
      "servings": { "type": "integer", "minimum": 1 },
      "prep_minutes": { "type": "integer", "minimum": 0 },
      "cook_minutes": { "type": "integer", "minimum": 0 },
      "ingredients": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["item"],
          "properties": {
            "item": { "type": "string" },
            "amount": { "type": "string" },
            "note": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "steps": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "tags": { "type": "array", "items": { "type": "string" } }
    },
    "additionalProperties": false
  }
}
